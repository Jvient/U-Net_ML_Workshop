    "id": "026c02c1-e95c-4dca-930f-e30cbf317b4b"
   },
   "source": [
    "Maintenant nous pouvons mettre en place le traitement par ACP sur notre dataset. Nous allons viser 99% de VE pour notre reconstruction."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 40,
   "id": "600207bb-0c8c-4f13-be44-69c463a0366c",
   "metadata": {
    "executionInfo": {
     "elapsed": 11490,
     "status": "ok",
     "timestamp": 1765191462212,
     "user": {
      "displayName": "Jean-Marie Vient",
      "userId": "18269724500149014883"
     },
     "user_tz": -60
    },
    "id": "600207bb-0c8c-4f13-be44-69c463a0366c"
   },
   "outputs": [],
   "source": [
    "from sklearn.decomposition import PCA\n",
    "ACP_train = np.load('/content/drive/MyDrive/Ateliershom/ACP_train.npy')\n",
    "X_previ= np.load('/content/drive/MyDrive/Ateliershom/X_previ.npy')\n",
    "pca = PCA(n_components=0.99)\n",
    "pcaglory = pca.fit(ACP_train.reshape(ACP_train.shape[0],-1))\n",
    "transformglory = pcaglory.transform(X_previ.reshape(X_previ.shape[0],-1))\n",
    "X_r = pca.inverse_transform(transformglory)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d0a57669-9617-40fc-b109-729493207a6d",
   "metadata": {
    "id": "d0a57669-9617-40fc-b109-729493207a6d"
   },
   "outputs": [],
   "source": [
    "X_r = X_r.reshape(X_r.shape[0],121,121)"
   ]
  },
