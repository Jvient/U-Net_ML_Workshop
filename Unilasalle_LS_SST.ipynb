    "def month_to_season(month):\n",
    "    if month in (12, 1, 2):\n",
    "        return \"DJF\"\n",
    "    elif month in (3, 4, 5):\n",
    "        return \"MAM\"\n",
    "    elif month in (6, 7, 8):\n",
    "        return \"JJA\"\n",
    "    else:\n",
    "        return \"SON\""
   ]
